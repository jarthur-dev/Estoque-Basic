{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/css/(.*)",
      "dest": "css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "js/$1"
    },
    {
      "src": "/img/(.*)",
      "dest": "img/$1"
    },
    {
      "src": "/",
      "dest": "html/listagem.html"
    },
    {
      "src": "/html/(.*)",
      "dest": "html/$1"
    }
  ]
}